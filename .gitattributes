# Normalize line endings to LF for all text files
* text=auto eol=lf

# Treat binary files as binary (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.pdf binary
