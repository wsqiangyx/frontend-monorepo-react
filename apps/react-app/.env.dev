# Copy this file to .env.local or .env.development inside apps/react-app.
# Enable MSW only when you want the app to use the shared mock layer locally.

VITE_ENABLE_MSW=true

# 后端 API 代理地址（取消注释并设置后，/api/* 请求会转发到该地址）
# VITE_API_PROXY_TARGET=http://localhost:8080

# 在启用 Mock 的前提下，需要透传到真实后端的接口路径（逗号分隔）
# VITE_MOCK_PASSTHROUGH=/api/user,/api/dashboard/summary
