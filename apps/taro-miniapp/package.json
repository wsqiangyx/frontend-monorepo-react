    "@repo/shared-utils": "workspace:*",
    "@tarojs/components": "catalog:",
    "@tarojs/helper": "catalog:",
    "@tarojs/plugin-framework-react": "catalog:",
    "@tarojs/react": "catalog:",
    "@tarojs/runtime": "catalog:",
    "@tarojs/shared": "catalog:",
    "@tarojs/taro": "catalog:",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@tarojs/cli": "catalog:",
    "@tarojs/plugin-platform-weapp": "catalog:",
    "@tarojs/webpack5-runner": "catalog:",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "catalog:"
  }
