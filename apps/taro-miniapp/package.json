{
  "name": "@repo/taro-miniapp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "dev:h5": "taro build --type h5 --watch",
    "build:h5": "taro build --type h5",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/vitest.cjs run",
    "test:watch": "node ../../scripts/vitest.cjs",
    "test:coverage": "node ../../scripts/vitest.cjs run --coverage"
  },
  "dependencies": {
    "@repo/cross-platform-utils": "workspace:*",
