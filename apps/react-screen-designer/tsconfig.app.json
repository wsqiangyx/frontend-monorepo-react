{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@repo/shared": ["../../packages/shared/src/index.ts"],
      "@repo/platform-core": ["../../packages/platform-core/src/index.ts"],
      "@repo/mock/browser": ["../../packages/mock/src/browser.ts"],
      "@repo/mock/server": ["../../packages/mock/src/server.ts"],
      "@repo/design-tokens/theme": ["../../packages/design-tokens/src/theme/index.ts"],
      "@repo/design-tokens/css": ["../../packages/design-tokens/src/to-css.ts"],
      "@repo/design-tokens/theme/antd": ["../../packages/design-tokens/src/theme/antd.ts"],
      "@repo/ui-react": ["../../packages/ui-react/src/index.ts"],
      "@repo/ui-react/style.css": ["../../packages/ui-react/src/style.css"],
      "@repo/resources": ["../../packages/resources/src/index.ts"],
      "@repo/resources/*": ["../../packages/resources/src/*/index.ts"]
    }
  },
  "include": ["src"]
}
