{
  "name": "@repo/shared-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./style.css": {
      "default": "./dist/index.css"
    }
  },
  "scripts": {
    "build": "node -e \"import{rmSync,copyFileSync}from'node:fs';rmSync('dist',{recursive:true,force:true});rmSync('tsconfig.build.tsbuildinfo',{force:true});\" && node ../../scripts/vite.cjs build && node -e \"import{copyFileSync}from'node:fs';copyFileSync('src/style.css','dist/index.css');\" && tsc --emitDeclarationOnly -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/vitest.cjs run",
    "test:watch": "node ../../scripts/vitest.cjs",
    "test:coverage": "node ../../scripts/vitest.cjs run --coverage"
  },
  "dependencies": {
    "@repo/shared-service": "workspace:*",
    "@repo/shared-utils": "workspace:*",
    "@repo/design-tokens": "workspace:*",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "tailwind-merge": "catalog:",
    "lucide-react": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-alert-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-progress": "catalog:",
    "@radix-ui/react-scroll-area": "catalog:",
    "@radix-ui/react-accordion": "catalog:",
    "@radix-ui/react-toast": "catalog:",
    "@radix-ui/react-toggle": "catalog:",
    "@radix-ui/react-toggle-group": "catalog:",
    "@radix-ui/react-collapsible": "catalog:",
    "@radix-ui/react-slider": "catalog:",
    "@radix-ui/react-aspect-ratio": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "peerDependencies": {
    "cmdk": "catalog:",
    "vaul": "catalog:",
    "react-hook-form": "catalog:",
    "@hookform/resolvers": "catalog:",
    "zod": "catalog:"
  },
  "peerDependenciesMeta": {
    "cmdk": {
      "optional": true
    },
    "vaul": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "vite": "catalog:"
  }
}
