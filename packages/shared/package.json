{
  "//": "@repo/shared - shared types, utilities, route definitions, and runtime helpers.",
  "//_name": "Internal monorepo package, not published to npm.",
  "name": "@repo/shared",
  "version": "0.0.0",
  "//_private": "private: true prevents accidental publication.",
  "private": true,
  "//_type": "ESM package aligned with the root workspace.",
  "type": "module",
  "//_main": "Primary runtime entry for tooling compatibility.",
  "main": "./dist/index.js",
  "//_types": "Primary type declaration entry.",
  "types": "./dist/index.d.ts",
  "//_exports": "Public package contract stays dist-only with explicit subpaths.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "default": "./dist/routes/index.js"
    },
    "./routes/react": {
      "types": "./dist/routes/react-adapter.d.ts",
      "default": "./dist/routes/react-adapter.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "default": "./dist/i18n/index.js"
    },
    "./ui-contract": {
      "types": "./dist/ui-contract/index.d.ts",
      "default": "./dist/ui-contract/index.js"
    }
  },
  "//_scripts": "Use the shared Vitest wrapper for Windows-safe execution.",
  "scripts": {
    "//_build": "Clean dist and tsbuildinfo before compiling tsconfig.build.json.",
    "build": "node -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true});rmSync('tsconfig.build.tsbuildinfo',{force:true});\" && tsc -p tsconfig.build.json",
    "//_typecheck": "Type-only validation without emit.",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/vitest.cjs run",
    "test:watch": "node ../../scripts/vitest.cjs",
    "test:coverage": "node ../../scripts/vitest.cjs run --coverage"
  },
  "dependencies": {
    "axios": "1.16.0"
  },
  "peerDependencies": {
    "react": "19.2.5",
    "react-router-dom": "^7.15.0"
  },
  "//_comment": "Framework adapters rely on consumer-installed framework/router peers.",
  "devDependencies": {
    "@types/react": "19.2.14"
  }
}
