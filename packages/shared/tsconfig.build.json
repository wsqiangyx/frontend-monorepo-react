// @repo/shared 的 TypeScript 构建配置 — tsc -p tsconfig.build.json 使用
// 继承 tsconfig.json（而非直接继承 base），在此基础上覆盖 noEmit 并排除测试文件。
// 覆盖 noEmit 是因为 tsconfig.base.json 未设定 noEmit（默认 false），
// 但如果未来 base 改为 noEmit: true，此处显式覆盖保证构建正常产出。
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // 显式开启文件产出（覆盖可能的 noEmit: true 继承）
    "noEmit": false,
    // 生成 .d.ts 声明文件，其他包通过 dist/index.d.ts 消费类型
    "declaration": true,
    // 生成声明文件的 source map，IDE "转到定义" 时跳转到源码而非 .d.ts
    "declarationMap": true,
    // 生成 JS source map，用于浏览器和测试调试
    "sourceMap": true
  },
  // 只编译 src/ 下的 .ts 文件
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  // 排除测试文件，它们不需要进入编译产物
  "exclude": ["src/**/*.test.ts"]
}
