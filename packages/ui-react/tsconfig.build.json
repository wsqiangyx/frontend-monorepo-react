{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@repo/platform-core": ["../platform-core/dist/index.d.ts"],
      "@repo/shared/ui-contract": ["../shared/dist/ui-contract/index.d.ts"],
      "@repo/design-tokens": ["../design-tokens/dist/index.d.ts"],
      "@repo/design-tokens/theme": ["../design-tokens/dist/theme/index.d.ts"],
      "@repo/design-tokens/theme/antd": ["../design-tokens/dist/theme/antd.d.ts"]
    }
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test/**/*"]
}
