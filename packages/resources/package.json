{
  "name": "@repo/resources",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "default": "./dist/assets/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "default": "./dist/icons/index.js"
    },
    "./svg": {
      "types": "./dist/svg/index.d.ts",
      "default": "./dist/svg/index.js"
    },
    "./sprite": {
      "types": "./dist/sprite/index.d.ts",
      "default": "./dist/sprite/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"import{rmSync}from'node:fs';rmSync('dist',{recursive:true,force:true});rmSync('tsconfig.build.tsbuildinfo',{force:true});\" && tsc -p tsconfig.build.json && node ./scripts/copy-assets.mjs && node ./scripts/assert-dist-assets.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node ../../scripts/vitest.cjs run",
    "test:watch": "node ../../scripts/vitest.cjs",
    "test:coverage": "node ../../scripts/vitest.cjs run --coverage"
  }
}
