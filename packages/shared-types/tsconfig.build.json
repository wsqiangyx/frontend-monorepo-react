// @repo/shared-types 的 TypeScript 构建配置 — tsc -p tsconfig.build.json 使用
// 继承 tsconfig.json，覆盖 noEmit 并排除测试文件。
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // 显式开启文件产出（覆盖可能的 noEmit: true 继承）
    "noEmit": false,
    // 生成 .d.ts 声明文件，其他包通过 dist/index.d.ts 消费类型
    "declaration": true,
    // 生成声明文件的 source map，IDE "转到定义" 时跳转到源码而非 .d.ts
    "declarationMap": true,
    // 生成 JS source map，用于浏览器和测试调试
    "sourceMap": true
  },
  // 只编译 src/ 下的 .ts 文件
  "include": ["src/**/*.ts"],
  // 排除测试文件，它们不需要进入编译产物
  "exclude": ["src/**/*.test.ts"]
}
