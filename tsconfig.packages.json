    { "path": "./packages/shared-service/tsconfig.build.json" },
    { "path": "./packages/design-tokens/tsconfig.build.json" },
    { "path": "./packages/resources/tsconfig.build.json" },
    { "path": "./packages/mock/tsconfig.build.json" },
    { "path": "./packages/shared-ui/tsconfig.build.json" }
  ]
}
